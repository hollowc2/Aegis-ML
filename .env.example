# ============================================================
# Aegis-ML — LLM Firewall Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ------ Backend LLM (llama.cpp / OpenAI-compatible) ------
# URL of your local llama.cpp server's OpenAI-compatible endpoint
BACKEND_URL=http://localhost:8080/v1/chat/completions

# Optional: API key for the backend (leave blank for local llama.cpp)
BACKEND_API_KEY=

# ------ Classifier Selection ------
# "sklearn" = Phase 1 (fast, lightweight, default)
# "hf"      = Phase 2 (fine-tuned DistilBERT/DeBERTa, GPU recommended)
CLASSIFIER_TYPE=sklearn

# ------ Confidence Threshold ------
# Requests with injection probability >= this value are blocked.
# Range: 0.0-1.0. Lower = stricter (more false positives).
CONFIDENCE_THRESHOLD=0.70

# ------ Rate Limiting ------
RATE_LIMIT_PER_MINUTE=60

# ------ Logging ------
LOG_LEVEL=INFO
# Set to "true" to redact prompt text from logs (GDPR-friendly)
REDACT_PROMPTS_IN_LOGS=false

# ------ Database ------
DATABASE_URL=sqlite+aiosqlite:///./logs/aegis_audit.db

# ------ Model Paths ------
# Path to the trained scikit-learn model artifact (.joblib)
SKLEARN_MODEL_PATH=models/sklearn_classifier.joblib

# Path to the fine-tuned HuggingFace model directory
HF_MODEL_PATH=models/hf_classifier

# ------ Canary Tokens ------
# Length of the random canary token string inserted into system prompts
CANARY_TOKEN_LENGTH=32

# ------ Service ------
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ------ Demo UI ------
DEMO_PORT=7860
# URL of the Aegis-ML API (for Gradio demo to call)
AEGIS_API_URL=http://localhost:8000
